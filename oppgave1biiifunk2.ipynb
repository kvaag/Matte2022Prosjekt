   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def V(U):\n",
    "    return -np.e**(np.log(2)*U) + 2\n",
    "\n",
    "U = np.linspace(0,1,100)\n",
    "\n",
    "V_Values = V(U)\n",
    "\n",
    "plt.plot(U,V_Values)\n",
    "plt.xlabel(\"U(U/Umax\")\n",
    "plt.ylabel(\"V(V/Vmax\")\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ]
  },
